# =============================================================================
# 애플리케이션 설정
# =============================================================================
DEBUG=false
SECRET_KEY=change-me-to-random-secret-key
JWT_SECRET=change-me-to-random-jwt-secret  # 최소 32자 이상 필수 (미만 시 HMAC 경고 발생)

# 거래 환경: paper(모의) / live(실전)
TRADING_ENV=paper

# =============================================================================
# 데이터베이스 (PostgreSQL)
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stockbot
POSTGRES_USER=stockbot
POSTGRES_PASSWORD=change-me-to-strong-password

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# 프론트엔드 + 인증
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
# Docker Compose 내부 서비스 간 통신용 (프론트→백엔드 프록시)
INTERNAL_API_URL=http://backend:8000
# 허용할 CORS 출처 (쉼표 구분, 예: http://localhost:3000,https://stockbot.choiji.kr)
ALLOWED_ORIGINS=http://localhost:3000
# 웹 대시보드 로그인 비밀번호 (빈 값이면 로그인 불가)
ADMIN_PASSWORD=
# JWT 토큰 만료 시간 (시간 단위, 기본 24)
JWT_EXPIRY_HOURS=24

# =============================================================================
# 한국투자증권 API (모의거래)
# https://openapi.koreainvestment.com
# =============================================================================
# KIS 종목 마스터파일 다운로드 베이스 URL (URL 변경 시 코드 수정 없이 대응)
KIS_MST_BASE_URL=https://new.real.download.dws.co.kr/common/master

KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=
KIS_MOCK_ACCOUNT_NO=

# =============================================================================
# 한국투자증권 API (실전거래)
# =============================================================================
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# =============================================================================
# 네이버 검색 API
# https://developers.naver.com
# =============================================================================
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# =============================================================================
# Open Dart API
# https://opendart.fss.or.kr
# =============================================================================
DART_API_KEY=

# =============================================================================
# 공공데이터포털 API (시가총액 데이터)
# https://www.data.go.kr → "금융위원회_주식시세정보" 활용 신청
# =============================================================================
DATA_GO_KR_API_KEY=

# =============================================================================
# Telegram Bot API
# https://t.me/BotFather
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=
