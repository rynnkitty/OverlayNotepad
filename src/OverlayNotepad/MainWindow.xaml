<Window x:Class="OverlayNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverlayNotepad"
        Width="400"
        Height="300"
        MinWidth="200"
        MinHeight="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FocusManager.FocusedElement="{Binding ElementName=MainTextBox}"
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="8"
                      CornerRadius="0"
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <!-- 드래그 영역 (상단 12px) -->
        <Border Height="12"
                VerticalAlignment="Top"
                Background="Transparent"
                MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0DFFFFFF" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- 텍스트 입력 영역 (드래그 영역 아래 전체) -->
        <TextBox x:Name="MainTextBox"
                 Margin="0,12,0,0"
                 Background="Transparent"
                 BorderThickness="0"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="맑은 고딕"
                 FontSize="14"
                 Foreground="#FFFFFF"
                 CaretBrush="#FFFFFF" />
    </Grid>
</Window>
