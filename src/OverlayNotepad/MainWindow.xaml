<Window x:Class="OverlayNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OverlayNotepad.Controls"
        Title="OverlayNotepad"
        Width="400"
        Height="300"
        MinWidth="200"
        MinHeight="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Opacity="0.8"
        FocusManager.FocusedElement="{Binding ElementName=MainTextBox}"
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="8"
                      CornerRadius="0"
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.ContextMenu>
        <ContextMenu Opened="ContextMenu_Opened">
            <MenuItem Header="투명도" x:Name="OpacityMenu">
                <MenuItem Header="20%" Tag="0.2" Click="OpacityMenuItem_Click" />
                <MenuItem Header="40%" Tag="0.4" Click="OpacityMenuItem_Click" />
                <MenuItem Header="60%" Tag="0.6" Click="OpacityMenuItem_Click" />
                <MenuItem Header="80%" Tag="0.8" IsChecked="True" Click="OpacityMenuItem_Click" />
                <MenuItem Header="100%" Tag="1.0" Click="OpacityMenuItem_Click" />
            </MenuItem>
            <Separator />
            <MenuItem x:Name="BackgroundTransparentMenuItem" Header="배경 투명 모드" IsCheckable="True" IsChecked="True"
                      Click="BackgroundTransparentMenuItem_Click" />
            <MenuItem x:Name="AlwaysOnTopMenuItem" Header="항상 위에" IsCheckable="True" IsChecked="True"
                      Click="AlwaysOnTopMenuItem_Click" />
            <Separator />
            <MenuItem x:Name="ThemeMenuItem" Header="테마: 다크 -&gt; 라이트" Click="ThemeMenuItem_Click" />
            <MenuItem x:Name="FontFamilyMenu" Header="글꼴" SubmenuOpened="FontFamilyMenu_SubmenuOpened">
                <MenuItem Header="로딩 중..." IsEnabled="False" />
            </MenuItem>
            <MenuItem x:Name="FontSizeMenu" Header="글자 크기">
                <MenuItem Header="10" Tag="10" Click="FontSizePreset_Click" />
                <MenuItem Header="12" Tag="12" Click="FontSizePreset_Click" />
                <MenuItem Header="14" Tag="14" IsChecked="True" Click="FontSizePreset_Click" />
                <MenuItem Header="16" Tag="16" Click="FontSizePreset_Click" />
                <MenuItem Header="20" Tag="20" Click="FontSizePreset_Click" />
                <MenuItem Header="24" Tag="24" Click="FontSizePreset_Click" />
                <MenuItem Header="32" Tag="32" Click="FontSizePreset_Click" />
                <Separator />
                <MenuItem Header="직접 입력..." Click="FontSizeCustom_Click" />
            </MenuItem>
            <MenuItem x:Name="FontColorMenu" Header="글자 색상" />
            <Separator />
            <MenuItem x:Name="OutlineMenuItem" Header="텍스트 테두리" IsCheckable="True" IsChecked="True"
                      Click="OutlineMenuItem_Click" />
            <MenuItem x:Name="OutlineColorMenu" Header="테두리 색상" />
            <MenuItem x:Name="ShadowMenuItem" Header="텍스트 그림자" IsCheckable="True" IsChecked="True"
                      Click="ShadowMenuItem_Click" />
            <Separator />
            <MenuItem x:Name="AutoSaveStatusMenuItem" Header="자동 저장됨" IsEnabled="False" />
            <Separator />
            <Separator />
            <MenuItem x:Name="ClickThroughMenuItem" Header="Click-Through" IsCheckable="True" IsChecked="False" />
            <MenuItem Header="최소화" Click="MinimizeMenuItem_Click" />
            <MenuItem Header="종료" Click="ExitMenuItem_Click" />
        </ContextMenu>
    </Window.ContextMenu>
    <Border x:Name="MainBackground" Background="Transparent">
        <Grid>
            <!-- Click-Through 점선 테두리 (항상 최상위) -->
            <Rectangle x:Name="ClickThroughIndicator"
                       Stroke="#FF4444"
                       StrokeThickness="3"
                       StrokeDashArray="4 2"
                       IsHitTestVisible="False"
                       Visibility="Collapsed" />

            <!-- 드래그 영역 (상단 12px) -->
            <Border x:Name="DragBar"
                    Height="12"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0DFFFFFF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <!-- Click-Through 상태 텍스트 -->
                <TextBlock x:Name="ClickThroughLabel"
                           Text="CLICK-THROUGH"
                           Foreground="#FF4444"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Visibility="Collapsed" />
            </Border>

            <!-- 텍스트 영역 (드래그 영역 아래) -->
            <Grid Margin="0,12,0,0">
                <local:OutlinedTextControl x:Name="OutlinedText"
                                           IsHitTestVisible="False"
                                           Visibility="Visible" />
                <TextBox x:Name="MainTextBox"
                         Background="Transparent"
                         BorderThickness="0"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="맑은 고딕"
                         FontSize="14"
                         Foreground="Transparent"
                         CaretBrush="#FFFFFF"
                         ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=Window}}"
                         TextChanged="MainTextBox_TextChanged"
                         ScrollViewer.ScrollChanged="MainTextBox_ScrollChanged">
                    <TextBox.Effect>
                        <DropShadowEffect x:Name="TextShadowEffect"
                                          ShadowDepth="1.5"
                                          BlurRadius="5"
                                          Opacity="0.8"
                                          Color="Black"
                                          Direction="315" />
                    </TextBox.Effect>
                </TextBox>
            </Grid>
        </Grid>
    </Border>
</Window>
